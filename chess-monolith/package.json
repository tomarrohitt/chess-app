{
  "name": "chess-monolith",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS='--network-family-autoselection-attempt-timeout=500' nodemon --exec tsx src/index.ts",
    "build": "npx tsc --build --force",
    "start": "node -r dotenv/config dist/src/index.js",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx src/seed/setup.ts && tsx src/seed/seed-users.ts",
    "db:push": "drizzle-kit push",
    "setup": "npm install && npm run build && npm run db:generate && npm run db:setup-extensions && npm run db:push && npm run seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-auth": "^1.4.19",
    "bullmq": "^5.70.1",
    "chess.js": "^1.4.0",
    "cloudinary": "^2.9.0",
    "cookie": "^1.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "ioredis": "^5.9.3",
    "multer": "^2.1.1",
    "postgres": "^3.4.8",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.3",
    "eslint-plugin-import": "^2.32.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
